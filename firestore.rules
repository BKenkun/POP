/**
 * @fileoverview Firestore Security Rules for PuroRush App
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for private data and allows public read access to product information. User data is stored under their respective `/users/{userId}` path, ensuring only the authenticated user can access their profile, shopping carts, and orders.
 *
 * Data Structure:
 * - `/products/{productId}`: Publicly accessible product catalog.
 * - `/users/{userId}`: User profile information, accessible only by the user.
 * - `/users/{userId}/shoppingCarts/{cartId}`: User's shopping cart, accessible only by the user.
 * - `/users/{userId}/orders/{orderId}`: User's order history, accessible only by the user.
 *
 * Key Security Decisions:
 * - User listing is implicitly denied by the path-based security model.
 * - Read-only collections (if any) are handled with `allow get, list: if true;`.
 * - Default security posture for ambiguous relationships is strict owner-only access.
 *
 * Denormalization for Authorization:
 *  The `userId` is present on both the `/shoppingCarts` and `/orders` subcollections so that rules can be written for each shopping cart or order without having to query other collections for the current user ID
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to product information. Only authenticated users can create, update, or delete products.
     * @path /products/{productId}
     * @allow get, list: if true;
     * @allow create: if isSignedIn(); // Only signed-in users can create products.
     * @allow update: if isSignedIn(); // Only signed-in users can update products.
     * @allow delete: if isSignedIn(); // Only signed-in users can delete products.
     * @principle Allows public read access but restrict write access to authenticated users.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Enforces user-ownership for shopping cart data. Only the authenticated user can access their own shopping cart.
     * @path /users/{userId}/shoppingCarts/{cartId}
     * @allow get, list: if isOwner(userId);
     * @allow create: if isOwner(userId) && request.resource.data.userId == userId;
     * @allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
     * @allow delete: if isExistingOwner(userId);
     * @principle Enforces document ownership and relational integrity for shopping carts.
     */
    match /users/{userId}/shoppingCarts/{cartId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for order data. Only the authenticated user can access their own order history.
     * @path /users/{userId}/orders/{orderId}
     * @allow get, list: if isOwner(userId);
     * @allow create: if isOwner(userId) && request.resource.data.userId == userId;
     * @allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
     * @allow delete: if isExistingOwner(userId);
     * @principle Enforces document ownership and relational integrity for orders.
     */
    match /users/{userId}/orders/{orderId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for user profile data. Only the authenticated user can access their own profile.
     * @path /users/{userId}
     * @allow get: if isOwner(userId);
     * @allow create: if isOwner(userId) && request.resource.data.id == userId;
     * @allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
     * @allow delete: if isExistingOwner(userId);
     * @principle Enforces document ownership and relational integrity for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    // --- Helper functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}