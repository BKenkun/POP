/**
 * @fileoverview Firestore Security Rules for PuroRush application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for cart items and orders,
 * while allowing public read access to the product catalog.  Reservations
 * can be created by anyone, but only updated/deleted by an admin user.
 *
 * Data Structure:
 * - /products/{productId}: Public product catalog.
 * - /users/{userId}/cart_items/{cartItemId}: User-specific shopping cart items.
 * - /users/{userId}/orders/{orderId}: User-specific order history.
 * - /reservations/{reservationId}: Reservations, which must have a userId.
 *
 * Key Security Decisions:
 * - Products are publicly readable, but only the application backend can create, update or delete them (TODO).
 * - Users can only manage their own cart items and orders.
 * - Listing of user cart items and orders is allowed only for the owner.
 * - Reservations can be created by anyone but are only managed by the backend (TODO).
 *
 * Denormalization for Authorization:
 *  - The `/reservations/{reservationId}` document requires a denormalized `userId` field to enforce ownership.
 *    This avoids costly `get()` calls to other collections for authorization.
 *
 * Structural Segregation:
 *  - User-specific data (cart items, orders) is stored under the `/users/{userId}` path to leverage path-based authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows public read access to product information.
     * @path /products/{productId}
     * @allow (get, list): if true
     * @deny (create, update, delete): if false
     * @principle Allows public read access while restricting write access.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Only allow from backend
    }

    /**
     * @description Manages user-specific cart items.
     * @path /users/{userId}/cart_items/{cartItemId}
     * @allow (create): if isSignedIn() && isOwner(userId)
     * @allow (get, list): if isSignedIn() && isOwner(userId)
     * @allow (update, delete): if isSignedIn() && isExistingOwner(userId)
     * @deny (create): if !isSignedIn() || !isOwner(userId)
     * @deny (get, list): if !isSignedIn() || !isOwner(userId)
     * @deny (update, delete): if !isSignedIn() || !isExistingOwner(userId)
     * @principle Enforces document ownership for cart items.
     */
    match /users/{userId}/cart_items/{cartItemId} {
      allow create: if isSignedIn() && isOwner(userId);
      allow get, list: if isSignedIn() && isOwner(userId);
      allow update, delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Manages user-specific order history.
     * @path /users/{userId}/orders/{orderId}
     * @allow (create): if isSignedIn() && isOwner(userId)
     * @allow (get, list): if isSignedIn() && isOwner(userId)
     * @allow (update, delete): if isSignedIn() && isExistingOwner(userId)
     * @deny (create): if !isSignedIn() || !isOwner(userId)
     * @deny (get, list): if !isSignedIn() || !isOwner(userId)
     * @deny (update, delete): if !isSignedIn() || !isExistingOwner(userId)
     * @principle Enforces document ownership for orders.
     */
    match /users/{userId}/orders/{orderId} {
      allow create: if isSignedIn() && isOwner(userId);
      allow get, list: if isSignedIn() && isOwner(userId);
      allow update, delete: if isSignedIn() && isExistingOwner(userId);
    }
    
        /**
     * @description Allows anyone to create reservations, but only admins can update/delete them.
     * @path /reservations/{reservationId}
     * @allow (create): if request.resource.data.userId == request.auth.uid || request.resource.data.userId == 'guest';
     * @allow (get): if true;
     * @allow (update, delete): if false; // TODO: Only allow from backend
     * @deny (create): if request.resource.data.userId != request.auth.uid && request.resource.data.userId != 'guest';
     * @principle Allows reservations by authenticated users or guests, restricts modification to admins.
     */
    match /reservations/{reservationId} {
        allow create: if request.auth != null && (request.resource.data.userId == request.auth.uid || request.resource.data.userId == 'guest');
        allow get: if true;
        allow list: if false;
        allow update, delete: if false; // TODO: Only allow from backend
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}