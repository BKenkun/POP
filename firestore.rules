
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Allow admins to do anything
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "maryandpopper@gmail.com";
    }

    // Reglas para la colección de usuarios
    match /users/{userId} {
      // Un usuario solo puede leer o escribir en su propio documento
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Un usuario solo puede listar sus propios pedidos
      match /orders/{orderId} {
        allow read, list, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Reglas para la colección de reservas de invitados
    match /reservations/{reservationId} {
      // Los invitados (sin autenticar) solo pueden crear una reserva nueva.
      allow write: if request.auth == null;
      // Nadie puede leer, actualizar o eliminar reservas de otros.
      allow read, update, delete: if false;
    }

    // Reglas para las consultas collectionGroup
    // Permite a usuarios autenticados (y por ende al admin) listar pedidos de todos los usuarios
    match /{path=**}/orders/{orderId} {
      allow list: if request.auth != null;
      // Las reglas de lectura/escritura se heredan de la ruta /users/{userId}/orders/{orderId}
      allow read, write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true || request.auth.uid == path[1];
    }
  }
}
