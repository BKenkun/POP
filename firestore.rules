
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'maryandpopper@gmail.com';
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      // Ensure a user can only create a document with their own UID.
      allow create: if isSignedIn() && request.auth.uid == userId && request.resource.data.id == userId;
      
      // A user can ONLY update their own addresses, loyalty points, or subscription status.
      // An admin can update any field (and their access is not governed by these rules when using Admin SDK).
      // This rule is critical for client-side security.
      allow update: if (isOwner(userId) && request.resource.data.keys().hasOnly(['addresses', 'loyaltyPoints', 'isSubscribed', 'subscription'])) || isAdmin();

      allow delete: if isExistingOwner(userId) || isAdmin();

      match /shoppingCarts/{cartId} {
        allow read, write: if isOwner(userId);
      }

      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId) || isAdmin();
        allow delete: if isExistingOwner(userId) || isAdmin();
      }
    }
    
    // This rule allows the admin (via server-side Admin SDK which bypasses these rules)
    // to query across all 'orders' subcollections. It's good practice to have it,
    // but the primary security for the admin panel now lies in the Server Actions.
    match /{path=**}/orders/{orderId} {
       allow read, list: if isAdmin();
    }
  }
}
