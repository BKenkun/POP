
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'maryandpopper@gmail.com';
    }

    // Products are publicly readable by anyone.
    // Writing is restricted to admins.
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    
    // Coupons are readable by signed-in users.
    // Coupon creation and deletion is restricted to admins.
    // Users can UPDATE a coupon, but ONLY the 'usageCount' field.
    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if isSignedIn() && request.resource.data.keys().hasOnly(['usageCount']);
    }

    // User-specific data.
    match /users/{userId} {
      // An admin can see any user profile. A user can only see their own.
      allow get: if isOwner(userId) || isAdmin();
      // Only an admin can list all users.
      allow list: if isAdmin();
      
      // A user can only create their own user document.
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // A user can ONLY update specific, safe fields on their own document.
      // An admin can update any field (when using Admin SDK).
      allow update: if (isOwner(userId) && request.resource.data.keys().hasOnly(['addresses', 'loyaltyPoints', 'isSubscribed', 'subscription'])) || isAdmin();

      // A user can delete their own document, an admin can delete any.
      allow delete: if isExistingOwner(userId) || isAdmin();

      // Shopping carts and orders are private to the user.
      match /shoppingCarts/{cartId} {
        allow read, write: if isOwner(userId);
      }

      match /orders/{orderId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isExistingOwner(userId) || isAdmin();
      }
    }
    
    // This allows an admin to perform a collectionGroup query on all 'orders'.
    // It's essential for the admin panel dashboard and order list.
    match /{path=**}/orders/{orderId} {
       allow get, list: if isAdmin();
    }
  }
}
