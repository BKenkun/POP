# --- App URL (Hilow success/cancel redirects, Stripe, etc.) ---
# Usa tu dominio público en cada entorno (producción: https://comprarpopperonline.com).
NEXT_PUBLIC_APP_URL=https://your-domain.com
# Opcional: mismo valor solo en servidor si no quieres exponer la URL al cliente.
APP_BASE_URL=

# --- Hilow (pagos) ---
# API key del cliente (solo servidor; no la expongas al frontend).
HILOW_API_KEY=
# Secreto para verificar el webhook POST /api/webhooks/hilow (cabecera hilow-signature).
HILOW_WEBHOOK_SECRET=
# Opcional: host de la API (por defecto https://hilowglobal.com).
HILOW_API_BASE_URL=https://hilowglobal.com
# Opcional: origen donde abrir /pay/{hilowOrderId} si difiere (ej. https://pay.hilowglobal.com).
HILOW_PAY_ORIGIN=
# Opcional: hostname de tienda registrado en Hilow (debe coincidir con domains del cliente).
HILOW_STORE_ID=comprarpopperonline.com
# Opcional: solo si reactivas useHilowPaymentListener (Firestore público de Hilow).
NEXT_PUBLIC_HILOW_FIREBASE_API_KEY=
NEXT_PUBLIC_HILOW_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_HILOW_FIREBASE_PROJECT_ID=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Klaviyo ---
KLAVIYO_API_KEY=
KLAVIYO_LIST_ID=

# --- Firebase (cliente) ---
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase Admin (servidor: webhooks, login con cookie, etc.) ---
# JSON completo del service account en una sola línea (descarga desde Firebase Console > Project settings > Service accounts).
# Si antes hubo credenciales en el código, genera una clave nueva y rota la antigua en Google Cloud.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Opcional si usas applicationDefault() y GOOGLE_APPLICATION_CREDENTIALS apunta a un archivo JSON.
FIREBASE_PROJECT_ID=
# Opcional: bucket (por defecto {project_id}.appspot.com).
FIREBASE_STORAGE_BUCKET=
